# Copy this file to `.env` and adjust the values.
# SQLite database file (path resolved from the project root).
DATABASE_URL="file:./prisma/dev.db"

# Realtime (Socket.IO) server
SOCKET_PORT=3001
# Origin allowed to connect to the socket server (the Next app).
CLIENT_ORIGIN="http://localhost:3000"
# Public URL the browser uses to reach the socket server.
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
