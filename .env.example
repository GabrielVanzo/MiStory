# Copy this file to `.env` and adjust the values.
# SQLite database file (path resolved from the project root).
DATABASE_URL="file:./prisma/dev.db"

# Realtime (Socket.IO) server
SOCKET_PORT=3001
# Origin allowed to connect to the socket server (the Next app).
CLIENT_ORIGIN="http://localhost:3000"
# Public URL the browser uses to reach the socket server.
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"

# Room lifecycle timings (ms). Optional — sensible defaults are built in.
# HOST_GRACE_MS=30000      # host may be offline this long before host is transferred
# PLAYER_TTL_MS=120000     # an offline player keeps their seat this long
# ROOM_TTL_MS=120000       # a fully-offline room is deleted after this
# SWEEP_INTERVAL_MS=15000  # how often the reconciliation sweep runs
